import { Inject, Injectable, UnauthorizedException } from '@nestjs/common';
import type { ConfigType } from '@nestjs/config';
import { OAuth2Client } from 'google-auth-library';
import { googleAuthConfig } from '../config/google-auth.config';
import { JwtTokenProvider } from './jwt-token.provider';
import { GoogleLoginDto } from '../dto/google-login.dto';

@Injectable()
export class GoogleAuthProvider {
  private readonly client: OAuth2Client;

  constructor(
    @Inject(googleAuthConfig.KEY) private readonly googleConfig: ConfigType<typeof googleAuthConfig>,
    private readonly jwtTokenProvider: JwtTokenProvider,
  ) {
    this.client = new OAuth2Client(this.googleConfig.clientId);
  }

  async verifyIdToken(dto: GoogleLoginDto) {
    const ticket = await this.client.verifyIdToken({
      idToken: dto.idToken,
      audience: this.googleConfig.clientId,
    });
    const googlePayload = ticket.getPayload();
    if (!googlePayload?.email) throw new UnauthorizedException('Invalid Google token');

    // TODO: Find or create the user in your database using the verified Google identity
    // Example:
    //   const user = await this.usersService.findOrCreate({ email: googlePayload.email, googleId: googlePayload.sub });
    //   return this.jwtTokenProvider.generateTokens({ sub: user.id, email: user.email });
    return this.jwtTokenProvider.generateTokens({ sub: googlePayload.sub, email: googlePayload.email });
  }
}

import { Injectable } from '@nestjs/common';
import { JwtTokenProvider } from './jwt-token.provider';
import { EmailPasswordDto } from '../dto/email-password.dto';

@Injectable()
export class EmailAuthProvider {
  constructor(private readonly jwtTokenProvider: JwtTokenProvider) {}

  async validate(dto: EmailPasswordDto) {
    // TODO: Look up the user in your database and verify their password
    // Example:
    //   const user = await this.usersService.findByEmail(dto.email);
    //   if (!user || !(await bcrypt.compare(dto.password, user.passwordHash))) {
    //     throw new UnauthorizedException('Invalid credentials');
    //   }
    //   return this.jwtTokenProvider.generateTokens({ sub: user.id, email: user.email });
    return this.jwtTokenProvider.generateTokens({ sub: 'replace-with-user-id', email: dto.email });
  }
}

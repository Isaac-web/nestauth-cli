import { Inject, Injectable, UnauthorizedException } from '@nestjs/common';
import { JwtService } from '@nestjs/jwt';
import type { ConfigType } from '@nestjs/config';
import { authConfig } from '../config/auth.config';
import { JwtTokenProvider } from './jwt-token.provider';
import { RefreshTokenDto } from '../dto/refresh-token.dto';
import { TokenPayload } from '../interfaces/token-payload.interface';

@Injectable()
export class RefreshTokenProvider {
  constructor(
    private readonly jwtService: JwtService,
    @Inject(authConfig.KEY) private readonly config: ConfigType<typeof authConfig>,
    private readonly jwtTokenProvider: JwtTokenProvider,
  ) {}

  async validate(dto: RefreshTokenDto) {
    try {
      // Verify the incoming refresh token signature and expiry
      const payload = await this.jwtService.verifyAsync<TokenPayload>(dto.refreshToken, {
        secret: this.config.refreshTokenSecret,
      });
      // Issue a fresh token pair for the authenticated user
      return this.jwtTokenProvider.generateTokens({ sub: payload.sub, email: payload.email });
    } catch {
      throw new UnauthorizedException('Invalid refresh token');
    }
  }
}

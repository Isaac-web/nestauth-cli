import { Body, Controller, Post } from '@nestjs/common';
{{#if includeEmail}}
import { EmailPasswordDto } from './dto/email-password.dto';
{{/if}}
{{#if includeGoogle}}
import { GoogleLoginDto } from './dto/google-login.dto';
{{/if}}
{{#if includeRefreshToken}}
import { RefreshTokenDto } from './dto/refresh-token.dto';
{{/if}}
import { Auth } from './decorators/auth.decorator';
import { AuthType } from './enums/auth-type.enum';
import { AuthService } from './auth.service';

@Auth(AuthType.None)
@Controller('{{routePrefix}}')
export class AuthController {
  constructor(private readonly authService: AuthService) {}

  {{#if includeEmail}}
  @Post('login')
  login(@Body() emailPasswordDto: EmailPasswordDto) {
    return this.authService.loginWithEmail(emailPasswordDto.email, emailPasswordDto.password);
  }
  {{/if}}
  {{#if includeGoogle}}
  @Post('google')
  google(@Body() googleLoginDto: GoogleLoginDto) {
    return this.authService.loginWithGoogle(googleLoginDto.idToken);
  }
  {{/if}}
  {{#if includeRefreshToken}}
  @Post('refresh')
  refresh(@Body() refreshTokenDto: RefreshTokenDto) {
    return this.authService.refreshToken(refreshTokenDto.refreshToken);
  }
  {{/if}}
}

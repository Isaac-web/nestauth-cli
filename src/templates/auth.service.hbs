import { Injectable } from '@nestjs/common';
{{#if includeRefreshToken}}
import { RefreshTokenProvider } from './providers/refresh-token.provider';
import { RefreshTokenDto } from './dto/refresh-token.dto';
{{/if}}
{{#if includeEmail}}
import { EmailAuthProvider } from './providers/email-auth.provider';
import { EmailPasswordDto } from './dto/email-password.dto';
{{/if}}
{{#if includeGoogle}}
import { GoogleAuthProvider } from './providers/google-auth.provider';
import { GoogleLoginDto } from './dto/google-login.dto';
{{/if}}

@Injectable()
export class AuthService {
  constructor(
    {{#if includeRefreshToken}}
    private readonly refreshTokenProvider: RefreshTokenProvider,
    {{/if}}
    {{#if includeEmail}}
    private readonly emailAuthProvider: EmailAuthProvider,
    {{/if}}
    {{#if includeGoogle}}
    private readonly googleAuthProvider: GoogleAuthProvider,
    {{/if}}
  ) {}

  {{#if includeEmail}}
  async loginWithEmail(dto: EmailPasswordDto) {
    return this.emailAuthProvider.validate(dto);
  }

  {{/if}}
  {{#if includeGoogle}}
  async loginWithGoogle(dto: GoogleLoginDto) {
    return this.googleAuthProvider.verifyIdToken(dto);
  }

  {{/if}}
  {{#if includeRefreshToken}}
  async refreshToken(dto: RefreshTokenDto) {
    return this.refreshTokenProvider.validate(dto);
  }

  {{/if}}
}

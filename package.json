{
  "name": "@takiy/nestauth",
  "version": "0.1.0",
  "description": "Passport-free authentication boilerplate generator for NestJS",
  "main": "dist/index.js",
  "bin": {
    "nestauth": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc && cp -r src/templates dist/ && chmod +x dist/index.js",
    "prepublishOnly": "npm run build",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "jest"
  },
  "keywords": [
    "nestjs",
    "auth",
    "cli",
    "generator",
    "jwt",
    "authentication",
    "boilerplate"
  ],
  "author": "Isaac-web",
  "license": "ISC",
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Isaac-web/nest-auth-cli.git"
  },
  "homepage": "https://github.com/Isaac-web/nest-auth-cli#readme",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "fs-extra": "^11.3.6",
    "handlebars": "^4.7.9",
    "inquirer": "^14.0.2",
    "ora": "^9.4.1",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/handlebars": "^4.0.40",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
